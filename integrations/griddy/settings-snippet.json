{
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "mcp__open-brain__capture_thought",
        "hooks": [
          {
            "type": "command",
            "command": "$HOME/.local/bin/griddy --terminals",
            "timeout": 10,
            "async": true
          }
        ]
      }
    ],
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "python3 \"$HOME/.claude/hooks/griddy-on-capture.py\"",
            "timeout": 5,
            "async": true
          }
        ]
      }
    ]
  }
}
