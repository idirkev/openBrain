{
  "$schema": "https://www.raycast.com/schemas/extension.json",
  "name": "open-brain",
  "title": "Open Brain",
  "description": "Quick capture and search for Open Brain knowledge system",
  "icon": "command-icon.png",
  "author": "openbrain",
  "license": "MIT",
  "categories": [
    "Productivity",
    "Documentation"
  ],
  "commands": [
    {
      "name": "capture-thought",
      "title": "Capture Thought",
      "subtitle": "Open Brain",
      "description": "Quickly capture a thought to Open Brain",
      "mode": "view",
      "arguments": [
        {
          "name": "content",
          "placeholder": "Your thought...",
          "type": "text",
          "required": false
        }
      ]
    },
    {
      "name": "search-thoughts",
      "title": "Search Thoughts",
      "subtitle": "Open Brain",
      "description": "Search thoughts by meaning",
      "mode": "view"
    },
    {
      "name": "list-thoughts",
      "title": "List Recent Thoughts",
      "subtitle": "Open Brain",
      "description": "Browse recent thoughts with filters",
      "mode": "view"
    },
    {
      "name": "thought-stats",
      "title": "Thought Statistics",
      "subtitle": "Open Brain",
      "description": "View Open Brain statistics",
      "mode": "view"
    },
    {
      "name": "quick-capture",
      "title": "Quick Capture",
      "subtitle": "Open Brain",
      "description": "Capture thought without UI feedback",
      "mode": "no-view",
      "arguments": [
        {
          "name": "content",
          "placeholder": "Your thought...",
          "type": "text",
          "required": true
        }
      ]
    },
    {
      "name": "voice-capture",
      "title": "Voice Capture",
      "subtitle": "Open Brain",
      "description": "Capture thought using voice (Whisper transcription)",
      "mode": "view"
    }
  ],
  "preferences": [
    {
      "name": "mcpEndpoint",
      "title": "MCP Endpoint",
      "description": "Your Open Brain MCP edge function URL",
      "type": "textfield",
      "required": true,
      "placeholder": "https://your-project.supabase.co/functions/v1/open-brain-mcp"
    },
    {
      "name": "accessKey",
      "title": "Access Key",
      "description": "Your MCP_ACCESS_KEY for authentication",
      "type": "password",
      "required": true
    },
    {
      "name": "defaultDays",
      "title": "Default Days Back",
      "description": "Default number of days to look back when listing thoughts",
      "type": "textfield",
      "required": false,
      "default": "7"
    },
    {
      "name": "openaiApiKey",
      "title": "OpenAI API Key",
      "description": "For Whisper voice transcription (optional - only needed for voice capture)",
      "type": "password",
      "required": false,
      "placeholder": "sk-... (required for voice capture)"
    }
  ],
  "dependencies": {
    "@raycast/api": "^1.64.0",
    "@raycast/utils": "^1.10.0"
  },
  "devDependencies": {
    "@raycast/eslint-config": "^1.0.6",
    "@types/node": "20.8.10",
    "@types/react": "18.2.0",
    "eslint": "^8.51.0",
    "prettier": "^3.0.3",
    "typescript": "^5.2.2"
  },
  "scripts": {
    "build": "ray build --output dist",
    "dev": "ray develop",
    "fix-lint": "ray fix-lint",
    "lint": "ray lint",
    "publish": "npx @raycast/api@latest publish"
  }
}
